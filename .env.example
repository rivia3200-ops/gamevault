# ─── Site ────────────────────────────────────────────────────────────────────
# The canonical URL of your deployment (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://gamevault.vercel.app

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Your GA4 Measurement ID (starts with G-)
# Leave empty to disable analytics in production
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google AdSense ───────────────────────────────────────────────────────────
# Your AdSense publisher ID (starts with ca-pub-)
# Leave empty to show placeholder ad slots in production
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ─── Ad Slot IDs ──────────────────────────────────────────────────────────────
# Individual ad slot IDs from your AdSense account.
# If not set, the <AdSlot slot="..."> prop is used as fallback.
NEXT_PUBLIC_AD_SLOT_LEADERBOARD=1234567890
NEXT_PUBLIC_AD_SLOT_RECTANGLE=0987654321
NEXT_PUBLIC_AD_SLOT_SKYSCRAPER=1122334455
NEXT_PUBLIC_AD_SLOT_MOBILE_BANNER=5544332211

# ─── Google Search Console ────────────────────────────────────────────────────
# Verification meta tag value (the content= value, not the full tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token_here
